# ────────────────────────────────���────────
# Supabase (base de données)
# https://supabase.com → Nouveau projet → Settings → API
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ───────────────────────────���─────────────
# Google OAuth (connexion compte Google + Sheets)
# https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Redirect URI : https://campagne-ia.vercel.app/api/auth/callback/google
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxx
NEXTAUTH_SECRET=generez-avec-openssl-rand-base64-32
NEXTAUTH_URL=https://campagne-ia.vercel.app

# ─────────────────────────────────────────
# Vapi.ai (voix IA)
# https://vapi.ai → Dashboard → API Keys + Phone Numbers
# ─────────────────────────────────────────
VAPI_API_KEY=vapi_xxxxxxxxxxxxxxxxxxxxxxxx
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─────────────────────────────────────────
# Kavkom (opérateur VoIP français)
# https://kavkom.com → Espace client → API
# ─────────────────────────────────────────
KAVKOM_API_KEY=xxxxxxxxxxxxxxxx
KAVKOM_ACCOUNT_ID=ACC_xxxxxxxx
KAVKOM_DID_NUMBER=+33xxxxxxxxx

# ─────────────────────────────────────────
# Notion (optionnel — export leads)
# https://notion.so/my-integrations
# ─────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://campagne-ia.vercel.app
